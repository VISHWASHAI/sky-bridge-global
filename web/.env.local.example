# Copy to .env.local and fill with your Supabase project values
# (Supabase dashboard -> Project Settings -> API)
# These are safe to expose to the browser; Row Level Security protects your data.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Admin inbox (/admin) — SERVER ONLY, never exposed to the browser ---
# Supabase dashboard -> Project Settings -> API -> service_role secret key.
# This bypasses Row Level Security, so keep it secret (server env only).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
# A password you choose to log into /admin.
ADMIN_PASSWORD=choose-a-strong-password

# --- Public site URL ---
# Used for SEO metadata, sitemap, and the shareable customer tracking links.
# Set this to your custom domain once connected (e.g. https://skybridgeglobal.com).
# Leave unset to fall back to the Vercel URL.
NEXT_PUBLIC_SITE_URL=https://sky-bridge-global.vercel.app
